{
    "$schema": "https://community.rockrms.com/schema/2024-10-01/theme.schema.json",
    "name": "VRL NextGen",
    "description": "VRL NextGen Theme for public facing website.",
    "purpose": "web",
    "availableIconSets": ["fontawesome", "tabler"],
    "fields": [
        {
            "type":"panel",
            "title":"Base Theme",
            "expanded": true,
            "fields": [
                {
                    "type": "color",
                    "name": "Primary Color",
                    "variable": "base-primary",
                    "description": "The primary color.",
                    "default": "#005DD7"
                },
                {
                    "type": "image",
                    "name": "Site Logo",
                    "variable": "logo-image",
                    "description": "The logo that will be displayed throughout the site.",
                    "default": "~~/Assets/Images/logo.svg"
                },
                                {
                    "type": "image",
                    "name": "Site Opengraph Fallback",
                    "variable": "site-og-fallback",
                    "description": "Image attached to shared links.",
                    "default": "~~/Assets/Images/logo.svg"
                }
            ]
        },
        {
            "type":"panel",
            "title":"Secondary Theme",
            "expanded": false,
            "fields": [
                {
                    "type": "color",
                    "name": "Primary Color 2",
                    "variable": "base-primary2",
                    "description": "The primary color.",
                    "default": "#005DD7"
                },
                {
                    "type": "image",
                    "name": "Site Logo 2",
                    "variable": "logo-image2",
                    "description": "The logo that will be displayed throughout the site.",
                    "default": "~~/Assets/Images/logo.svg"
                },
                                {
                    "type": "image",
                    "name": "Site Opengraph Fallback 2",
                    "variable": "site-og-fallback2",
                    "description": "Image attached to shared links.",
                    "default": "~~/Assets/Images/logo.svg"
                }
            ]
        }
    ]
}
